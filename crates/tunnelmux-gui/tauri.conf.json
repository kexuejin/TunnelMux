{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TunnelMux",
  "version": "0.1.3",
  "identifier": "com.tunnelmux.gui",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TunnelMux",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "publisher": "TunnelMux",
    "shortDescription": "Desktop control console for TunnelMux tunnels, routes, and diagnostics.",
    "longDescription": "TunnelMux is a local desktop control console for operating tunnel lifecycle, route configuration, and diagnostics against a running tunnelmuxd daemon.",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
